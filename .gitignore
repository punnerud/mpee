# Rust build artifacts
target/
**/target/
*.rlib
*.rmeta

# OSM input data and engine caches — too large for git, regenerable.
# Anchored to the repo root so the demo's bundled SF cache (demo/data/*.gz)
# is still committed for GitHub Pages.
/data/
**/*.osm.pbf
**/*.osm.pbf.csr
**/*.osm.pbf.pp
**/*.osm.pbf.ch
**/*.csr
**/*.pp
**/*.ch
**/*.bak

# Benchmark output / generated datasets
**/instances/
**/instances_gh_200/
**/gh_canonical/
**/results/*.csv.tmp

# Editor / OS
.DS_Store
.vscode/
.idea/
*.swp

# Claude Code metadata
.claude/

# Python (for benchmark scripts in brooom)
__pycache__/
*.pyc
.venv/
venv/
venv/
*.so
